rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(householdId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    match /households/{householdId} {
      // Anyone signed in can create their own household (bootstrap on first login),
      // as long as they add themselves as the sole initial member.
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;
      allow read, update, delete: if request.auth != null &&
        request.auth.uid in resource.data.members;

      match /items/{itemId} {
        allow read, write: if isMember(householdId);
      }

      match /shoppingItems/{shoppingItemId} {
        allow read, write: if isMember(householdId);
      }
    }
  }
}
